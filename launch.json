{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug modbus_pm5560",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/modbus_pm5560.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "build modbus_pm5560",
      "setupCommands": [
        {
          "description": "Habilitar pretty-printing para gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
